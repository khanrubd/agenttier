# AgentTier deploy configuration
# Copy to config/config.env and edit; config/config.env is gitignored.
# All variables have defaults. Only set what you need to override.
#
# Usage: source config/config.env  (done automatically by deploy.sh)

# --- Registry / image ---
# Registry + repo prefix for built images.
# Local path: leave empty or use the local Docker daemon name (images are
#   side-loaded with kind/minikube, no push needed).
# EKS path: set to the ECR registry Terraform outputs (e.g.
#   123456789012.dkr.ecr.us-east-1.amazonaws.com/agenttier).
#   deploy.sh --target=eks reads ecr_registry from `terraform output` and
#   overrides this automatically.
AGENTTIER_REGISTRY=ghcr.io/agenttier

# Image tag to build and push.
# Empty → derived by scripts/lib/version.sh:
#   - VERSION file present + clean tree → vX.Y.Z (from VERSION)
#   - Otherwise                         → sha-<short-git-hash>
#   - Dirty tree                        → append -dirty
# Never defaults to "latest".
AGENTTIER_IMAGE_TAG=

# --- Helm chart ---
# Source chart from the local tree; publish path (ghcr.io Helm OCI or gh-pages)
# is for release-only. Build-from-source deploys always use the local chart.
AGENTTIER_CHART_REPO_URL=https://agenttier.github.io/agenttier/charts
AGENTTIER_DOCS_BASE_URL=https://agenttier.github.io/agenttier

# --- Deploy target ---
# local  → kind or minikube, side-loaded images, devAuth on, no IRSA/Cognito.
# eks    → Terraform (VPC + EKS + ECR + IRSA), buildx push, Cognito OIDC.
AGENTTIER_TARGET=local

# --- EKS-specific ---
# Build platform for EKS image push (must match node arch).
# Common values: linux/amd64 (Intel/AMD, default), linux/arm64 (Graviton).
AGENTTIER_EKS_PLATFORM=linux/amd64

# AWS region for Terraform + ECR.
AGENTTIER_AWS_REGION=us-east-1

# Terraform directory (relative to repo root).
AGENTTIER_TERRAFORM_DIR=terraform/aws-eks

# --- Local-specific ---
# Kind cluster name (for kind-based local deploys).
AGENTTIER_KIND_CLUSTER=agenttier-local

# Go module proxy for the Go-based image builds (passed through as
# --build-arg GOPROXY to docker/Dockerfile.controller, docker/Dockerfile.router, and all 6
# sandbox Dockerfiles on both the local and EKS local-buildx paths). Defaults
# to "https://proxy.golang.org,direct" (matches the Dockerfile ARG default).
# On networks where proxy.golang.org is unreachable (corporate VPN, some
# home/coffee-shop networks), set GOPROXY=direct to fetch modules straight
# from their VCS origins instead of hanging on `go mod download`. This is a
# plain (non-AGENTTIER_-prefixed) var so it matches the standard Go tooling
# env var name; export it in your shell or set it here — deploy.sh reads it
# with a ${GOPROXY:-...} fallback, it is not silently required.
# GOPROXY=direct

# Helm release name and namespace.
# AGENTTIER_NAMESPACE must match the Terraform helm_release namespace
# (agenttier.tf) — both default to "agenttier". Change together if you
# need a different namespace.
AGENTTIER_HELM_RELEASE=agenttier
AGENTTIER_NAMESPACE=agenttier

# --- EKS API endpoint exposure (agenttier-hardening) ---
# Mirrors terraform's var.endpoint_access_mode (terraform/aws-eks/variables.tf).
# public-restricted (default) → public endpoint on, narrow CIDR allowlist
#   required (0.0.0.0/0 rejected); terraform/kubectl/helm all reach the
#   cluster directly from wherever deploy.sh runs.
# private → public endpoint OFF entirely. terraform apply still runs locally
#   (pure AWS-API), but deploy.sh has no local path to the Kubernetes API, so
#   the on-cluster deploy/teardown steps are delegated to a CodeBuild project
#   running inside the VPC (forces AGENTTIER_USE_CODEBUILD=true — see below).
#   Human ops reach the private API via an SSM Session Manager port-forward;
#   see docs/docs/port-forwarding.md.
AGENTTIER_ENDPOINT_MODE=public-restricted

# Force the CodeBuild image-build path instead of local docker buildx.
# Empty (default) → auto-detect: CodeBuild is used only if local docker
#   buildx is unavailable (or AGENTTIER_ENDPOINT_MODE=private, which forces
#   it regardless of this setting — see deploy.sh's USE_CODEBUILD derivation).
# true  → always build via CodeBuild, even with local buildx available.
# false → prefer local buildx; deploy.sh still auto-falls back to CodeBuild
#   if local buildx is unavailable. The one case "false" is NOT honored:
#   combined with AGENTTIER_ENDPOINT_MODE=private, deploy.sh fails loudly
#   instead of silently overriding it (no local path to a private endpoint).
AGENTTIER_USE_CODEBUILD=

# --- AWS Load Balancer Controller (relocated from Terraform, D-U3/D-A1) ---
# deploy.sh installs the AWS Load Balancer Controller via helm after
# `aws eks update-kubeconfig` (public-restricted: locally; private: inside
# the CodeBuild-in-VPC deploy run) since the terraform helm_release for it
# was removed — terraform apply is now pure-AWS.
# Set to false to skip the LBC install (e.g. if you manage it separately).
AGENTTIER_INSTALL_LBC=true

# Helm chart version for eks-charts/aws-load-balancer-controller. The
# install/version toggle used to be terraform variables
# (install_aws_load_balancer_controller / aws_load_balancer_controller_chart_version)
# but those were removed from terraform/aws-eks/variables.tf as dead code —
# this pair of deploy.sh env vars is now the only place either lives.
AGENTTIER_LBC_CHART_VERSION=1.8.1
