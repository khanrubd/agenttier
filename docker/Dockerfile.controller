# Build stage — digest-pinned for supply-chain security (M5).
FROM public.ecr.aws/docker/library/golang:1.25.11-alpine@sha256:523c3effe300580ed375e43f43b1c9b091b68e935a7c3a92bfcc4e7ed55b18c2 AS builder

RUN apk add --no-cache git ca-certificates

# GOPROXY=direct bypasses proxy.golang.org. Default in Docker network is the
# proxy URL, but on networks where the proxy is blocked (corporate VPN /
# captive networks), the build hangs on `go mod download`. Override at build
# time with --build-arg GOPROXY=https://proxy.golang.org,direct when on a
# normal network.
ARG GOPROXY=https://proxy.golang.org,direct
ENV GOPROXY=${GOPROXY}
# GOTOOLCHAIN=local: never auto-download a toolchain; build with the image's
# Go (matches go.mod toolchain go1.25.11) so builds stay hermetic/offline (M5).
ENV GOTOOLCHAIN=local

WORKDIR /workspace

# Cache dependencies
COPY go.mod go.sum* ./
RUN go mod download

# Copy source
COPY cmd/ cmd/
COPY pkg/ pkg/
COPY api/ api/

# Build
ARG VERSION=dev
ARG GIT_COMMIT=unknown
RUN CGO_ENABLED=0 GOOS=linux go build \
    -trimpath \
    -ldflags="-s -w -X github.com/agenttier/agenttier/pkg/version.Version=${VERSION} -X github.com/agenttier/agenttier/pkg/version.GitCommit=${GIT_COMMIT}" \
    -o controller ./cmd/controller/

# Runtime stage — digest-pinned for supply-chain security (M5).
FROM gcr.io/distroless/static:nonroot@sha256:963fa6c544fe5ce420f1f54fb88b6fb01479f054c8056d0f74cc2c6000df5240

WORKDIR /

COPY --from=builder /workspace/controller .

USER 65532:65532

ENTRYPOINT ["/controller"]
